{"members": {"cols": ["id", "status", "name", "role", "grade", "group", "avatar", "intro", "message", "skills", "projects", "sort_order", "body", "updated_by", "created_at", "updated_at", "slug", "points_total"], "rows": [{"id": 1, "status": "current", "name": "郭宜展", "role": "在读学生", "grade": "2024 级", "group": "系统与驱动开发", "avatar": "/images/customers/model1.png", "intro": "2024级学生，熟练掌握C与Python，专注于Linux驱动开发。", "message": "擅长动手解决技术问题，具备良好的工程实践能力与自我驱动能力。", "skills": "[\"C\", \"Python\", \"Linux\", \"驱动开发\", \"前端\", \"深度学习\"]", "projects": "[]", "sort_order": 3, "body": "专注C++的算法程序员，擅长用C++实现高性能系统，并利用数据结构与算法优化解决方案。热爱技术探索，致力于编写高效、可维护的代码，持续在算法竞赛与工程实践中打磨技能。期待用代码解决复杂问题！", "updated_by": null, "created_at": "2026-05-14 10:41:09", "updated_at": "2026-05-20 12:19:00", "slug": "guo-yizhan", "points_total": 0}, {"id": 2, "status": "current", "name": "刘嘉鹏", "role": "在读学生", "grade": "2024 级", "group": "系统与驱动开发", "avatar": "/images/customers/model1.png", "intro": "2024级学生，熟练掌握C与Python，专注于Linux驱动开发。", "message": "擅长动手解决技术问题，具备良好的工程实践能力与自我驱动能力。", "skills": "[\"C\", \"Python\", \"Linux\", \"驱动开发\", \"前端\", \"深度学习\"]", "projects": "[]", "sort_order": 2, "body": "大一加入工作室，有丰富的学习经验和项目实践经历。写过飞机大战、2048等小游戏（使用pygame）和fastapi增删改查实践程序等。熟悉Python，JavaScript，Vue，CSS，HTML。", "updated_by": null, "created_at": "2026-05-14 10:41:09", "updated_at": "2026-05-20 12:19:00", "slug": "liu-jiapeng", "points_total": 0}, {"id": 3, "status": "current", "name": "王羿秋", "role": "在读学生", "grade": "2024 级", "group": "系统与驱动开发", "avatar": "/images/customers/model1.png", "intro": "2024级学生，熟练掌握C与Python，专注于Linux驱动开发。", "message": "擅长动手解决技术问题，具备良好的工程实践能力与自我驱动能力。", "skills": "[\"C\", \"Python\", \"Linux\", \"驱动开发\", \"前端\", \"深度学习\"]", "projects": "[]", "sort_order": 1, "body": "熟练掌握 C 与 Python，深度使用 Linux 并专注于驱动开发实践。同时对前端与深度学习也有持续探索，具备跨领域项目经验。擅长动手解决技术问题，具备良好的工程实践能力与自我驱动能力，期待在更高难度的技术场景中不断精进。", "updated_by": null, "created_at": "2026-05-14 10:41:09", "updated_at": "2026-05-20 12:19:00", "slug": "wang-yiqiu", "points_total": 0}, {"id": 4, "status": "alumni", "name": "常成彪", "role": "毕业成员", "grade": "2020 届", "group": "后端开发", "avatar": "/images/customers/model.png", "intro": "工作室第一批成员，主修后端开发", "message": "在工作室最大的收获，是第一次把一个想法从需求讨论推进到真正上线。", "skills": "[\"Java\", \"React\", \"PostgreSQL\"]", "projects": "[\"校园服务平台\", \"工作室内部工具\"]", "sort_order": 1, "body": "现就职于武汉，长期从事Java开发工作，深耕工业信息化领域，具备扎实的技术功底与丰富的项目落地经验。擅长MES生产执行系统、TPM设备管理系统、TWS相关系统及工业自动化数据采集分析系统的设计开发，精通业务流程梳理与优化，能精准拆解工业场景需求，搭建适配生产实际的技术方案。熟悉工业数据流转逻辑，可高效完成数据采集、分析及系统集成，助力打通生产各环节信息壁垒，提升生产效率与管理精细化水平，推动工业生产数字化、智能化升级，适配各类工业企业信息化建设需求。", "updated_by": null, "created_at": "2026-05-14 10:41:09", "updated_at": "2026-05-20 12:19:00", "slug": "chang-chengbiao", "points_total": 0}, {"id": 5, "status": "alumni", "name": "胡芳瑶", "role": "毕业成员", "grade": "2023届", "group": "UI设计", "avatar": "/images/customers/model1.png", "intro": "工作室毕业成员，主要负责UI设计，现从事内容运营工作。", "message": "在工作室期间的团队合作经历，为我积累了很多工作经验。", "skills": "[\"UI设计\", \"APP界面设计\", \"海报设计\", \"Photoshop\", \"Illustrator\", \"Premiere\", \"After Effects\"]", "projects": "[]", "sort_order": 8, "body": "现就职于郑州。作为工作室已经毕业的的一员。我主要负责UI设计板块，如：APP界面设计，海报设计等等。擅长Ps、Ai、Pr、Ae等，以实现视觉设计与用户体验优化。在工作室期间的团队合作经历，为我积累了很多工作经验，毕业后目前从事于内容运营的工作。期待学弟学妹加入我们工作室，一起迈向更好的未来！", "updated_by": null, "created_at": "2026-05-14 10:41:09", "updated_at": "2026-05-20 12:19:00", "slug": "hu-fangyao", "points_total": 0}, {"id": 6, "status": "alumni", "name": "李航", "role": "毕业成员", "grade": "2021 届", "group": "前端开发", "avatar": "/images/customers/model1.png", "intro": "2020年初识工作室，从前端项目入门，学会了主动解决问题。", "message": "我学到了我毕生受用的处理问题的方式，就是主动的面对问题而非一味的转移问题。", "skills": "[\"Vue\", \"ESLint\", \"前后端联调\"]", "projects": "[\"绩效后台管理系统\"]", "sort_order": 5, "body": "2020年初识工作室，从什么都不懂得小白，一步一步扣响01世界的大门。记得刚进入工作室老师带着我“玩”NAS。于是在我空洞的心里永恒的植入了0和1，使我对编程产生了空前的兴趣。于是紧跟着老师和刘桑合作了第一个vue项目《绩效后台管理系统》，记忆犹新的是其中的eslint（拼写检查）将我折磨的快要疯掉，我不断的问老师，不断的问老师。此时我对问题的理解就是不会就问，不做自己的思考。类似于抄作业式的询问然后填入答案。老师每次都是不厌其烦的教我如何上谷歌并搜索问题。当时没有get到老师的授人以渔，我只想抓住那条鱼。直到项目完成了90%只剩前后端对齐颗粒度，期间出了很多bug，面对bug我的第一反应是给老师打电话，而刘桑默默的打开了谷歌解决了问题……因而我学到了我毕生受用的处理问题的方式，就是主动的面对问题而非一味的转移问题。兴趣是第一内生驱动力，但只有驱动力是远远不够的，还需要外部环境的引导才能将内驱力转化为持续成长的关键，工作室对我而言就是这关键的外部环境。见证了我的成长我也见证了她的发展。衷心祝愿工作室能越办越好，能让更多的学弟学妹在此蜕变。", "updated_by": null, "created_at": "2026-05-14 10:41:09", "updated_at": "2026-05-20 12:19:00", "slug": "li-hang", "points_total": 0}, {"id": 7, "status": "alumni", "name": "刘凌彰", "role": "毕业成员", "grade": "2025 届", "group": "后端开发", "avatar": "/images/customers/model.png", "intro": "主修后端开发", "message": "在工作室最大的收获，是第一次把一个想法从需求讨论推进到真正上线。", "skills": "[\"Java\", \"React\", \"PostgreSQL\"]", "projects": "[\"校园服务平台\", \"工作室内部工具\"]", "sort_order": 11, "body": "现就职于深圳，在工作室四年，主要学习python和golang使我受益良多，感谢老师的精心培养，现在在公司负责web后端开发；平时好骑行，也喜欢折腾点小玩意。希望工作室越来越好！", "updated_by": null, "created_at": "2026-05-14 10:41:09", "updated_at": "2026-05-20 12:19:00", "slug": "liu-lingzhang", "points_total": 0}, {"id": 8, "status": "alumni", "name": "刘振伟", "role": "毕业成员", "grade": "2021 届", "group": "后端开发", "avatar": "/images/customers/model.png", "intro": "主修后端开发", "message": "工作室给我提供了一个宝贵的平台，老师的耐心指导和独立解决问题的思路，帮助我在技术上不断进步。", "skills": "[\"Go\", \"React\", \"PostgreSQL\"]", "projects": "[\"校园服务平台\", \"工作室内部工具\"]", "sort_order": 4, "body": "我在大学期间积累的编程经验让我在进入社会后顺利过渡。如今，我在成都的一家软件公司担任Golang后端开发工程师，主要负责广告统计业务的开发。我的技术栈主要包括Go语言、Python、MySQL、PostgreSQL、MongoDB、Redis等数据库技术，此外，我也熟练使用容器技术Docker和Kubernetes来管理和部署微服务。通过参与公司业务的开发，我不断提升自己的编程能力，也逐步从一个初学者成长为独立负责项目的开发者。\n回顾大学期间的学习和成长，工作室给我提供了一个宝贵的平台，老师的耐心指导和独立解决问题的思路，帮助我在技术上不断进步。如今，在工作中我也一直秉持这种思路，面对每一个挑战时，我都会从根本上去思考并解决问题，而不是仅仅依赖现有的解决方案。这种思维方式不仅影响了我的工作方式，也让我在生活中受益匪浅。", "updated_by": null, "created_at": "2026-05-14 10:41:09", "updated_at": "2026-05-20 12:19:00", "slug": "liu-zhenwei", "points_total": 0}, {"id": 9, "status": "alumni", "name": "孙庆飞", "role": "毕业成员", "grade": "2020 届", "group": "后端开发", "avatar": "/images/customers/model.png", "intro": "工作室第一批成员，主修前端开发", "message": "在工作室最大的收获，是第一次把一个想法从需求讨论推进到真正上线。", "skills": "[\"Java\", \"React\", \"PostgreSQL\"]", "projects": "[\"校园服务平台\", \"工作室内部工具\"]", "sort_order": 3, "body": "现就职于深圳，目前从事黄金期货交易方向的前端开发，主要负责交易系统的界面设计与功能实现。曾在云农业、畜牧业领域的嵌入式企业任职，参与多个项目，对传统行业的数字化有一定体会。兴趣广泛，对技术保持持续热情，除前端外也尝试过设计、安全、产品等方向，希望不断提升能力，让技术在更多真实场景中发挥价值。", "updated_by": null, "created_at": "2026-05-14 10:41:09", "updated_at": "2026-05-20 12:19:00", "slug": "sun-qingfei", "points_total": 0}, {"id": 10, "status": "alumni", "name": "唐毅博", "role": "在读学生", "grade": "2023届", "group": "前端与AI开发", "avatar": "/images/customers/model1.png", "intro": "研究生在读，有前端开发基础，现深入学习深度学习。", "message": "兴趣是第一内生驱动力，但只有驱动力是远远不够的，还需要外部环境的引导才能将内驱力转化为持续成长的关键。", "skills": "[\"JavaScript\", \"Vue\", \"React\", \"Python\", \"PyTorch\", \"深度学习\", \"数据处理\"]", "projects": "[]", "sort_order": 7, "body": "在工作室期间主要进行前端开发的学习，比较熟悉 JavaScript，使用过 Vue、React 这些主流框架和工程化工具。平时喜欢界面设计和交互优化，使用一些小组件。目前是研究生在读，正在深入学习深度学习相关内容，主要接触 Python、PyTorch，掌握各种模型构建和训练，进行数据处理，以及应用实践。", "updated_by": null, "created_at": "2026-05-14 10:41:09", "updated_at": "2026-05-29 10:26:34", "slug": "tang-yibo", "points_total": 0}, {"id": 11, "status": "alumni", "name": "吴浩宇", "role": "毕业成员", "grade": "2025 届", "group": "前端与3D开发", "avatar": "/images/customers/model1.png", "intro": "机器人工程专业，擅长前端开发与3D建模，现负责UE5开发及建模。", "message": "曾负责工作室项目“网络蜂巢”文件分享平台的前端开发。", "skills": "[\"前端开发\", \"3D建模\", \"UE5\"]", "projects": "[\"网络蜂巢\"]", "sort_order": 12, "body": "机器人工程专业，25届毕业生，擅长前端开发与3D建模基础。目前就职镜像视界 (浙江) 科技有限公司，负责UE5开发以及建模。曾负责工作室项目“网络蜂巢”文件分享平台的前端开发。", "updated_by": null, "created_at": "2026-05-14 10:41:09", "updated_at": "2026-05-20 12:19:00", "slug": "wu-haoyu", "points_total": 0}, {"id": 12, "status": "alumni", "name": "叶航", "role": "毕业成员", "grade": "2022 届", "group": "后端开发", "avatar": "/images/customers/model.png", "intro": "主修后端开发", "message": "在工作室最大的收获，是第一次把一个想法从需求讨论推进到真正上线。", "skills": "[\"Java\", \"React\", \"PostgreSQL\"]", "projects": "[\"校园服务平台\", \"工作室内部工具\"]", "sort_order": 6, "body": "现在上海读研，2020年冬天加入工作室。初来工作室时对代码的了解仅停留于道听途说，在没有接触任何培训和学习的基础上来到工作室时，我也觉得很迷茫。这些看着长串的code都是什么意思？程序为什么会跑起来？bug是怎样产生的，如何避免出bug？带着诸如此类的疑问和好奇，我留下来了，并且认真的学习了两年多。在此期间我与老师，同学一起参与制作了莫得丢小程序，并逐步升级至3.0版本。后来在对代码的进一步学习和理解之后，我也做出了自己的微信小程序——北林跳蚤市场。\n当自己做的程序出现在校园里，真的有人在上传和进行交易时，我想起自己晚上疯了一样找bug的那半个月，庆幸我在逻辑理论上已经解决了绝大部分可能会出现的bug，才能正常使程序运行。转瞬就毕业了，我目前在东莞从事CNC机加，机床操作技术员是我的日常工作，和数控机床交流的语言是G代码，尽管之前并没有接触过，但逻辑是通用的，在这里同事们一致认为我的逻辑十分严密，由我负责的机床，程序很少会出现问题。或许世界就是由巨大的0和1组成的吧。", "updated_by": null, "created_at": "2026-05-14 10:41:09", "updated_at": "2026-05-20 12:19:00", "slug": "ye-hang", "points_total": 0}, {"id": 13, "status": "alumni", "name": "张思宇", "role": "毕业成员", "grade": "2023届", "group": "UI设计", "avatar": "/images/customers/model.png", "intro": "工作室第一批成员，主修后端开发", "message": "在工作室最大的收获，是第一次把一个想法从需求讨论推进到真正上线。", "skills": "[\"Java\", \"React\", \"PostgreSQL\"]", "projects": "[\"校园服务平台\", \"工作室内部工具\"]", "sort_order": 9, "body": "在校期间主修数字媒体技术，擅长 Photoshop 与 UI/平面设计。一次偶然的机会加入了工作室，我非常喜欢那里浓厚的学习氛围；至今仍怀念与大家在工作室里一起讨论、钻研的美好时光。", "updated_by": null, "created_at": "2026-05-14 10:41:09", "updated_at": "2026-05-20 12:19:00", "slug": "zhang-siyu", "points_total": 0}, {"id": 14, "status": "alumni", "name": "赵锡盛", "role": "毕业成员", "grade": "2020 届", "group": "全栈开发", "avatar": "/images/customers/model.png", "intro": "工作室第一批成员，主修后端开发", "message": "在工作室最大的收获，是第一次把一个想法从需求讨论推进到真正上线。", "skills": "[\"Go\", \"React\", \"PostgreSQL\"]", "projects": "[\"校园服务平台\", \"工作室内部工具\"]", "sort_order": 2, "body": "现就职于武汉，从事Golang服务端研发，长期参与SaaS领域及数字娱乐相关系统建设，覆盖商品与价格体系、采购与供应链协同、高并发交易链路等核心业务。同时在App生态系统、内容/任务分发及调度系统等方向富有实践经验。技术方面熟悉 Golang、Python、Rust，具备微服务架构设计、服务治理与领域建模能力，参与过分布式任务调度、高并发交易系统等项目建设，在性能优化、可观测性、数据库与缓存设计、消息队列及工程化（CI/CD）方面有较多经验沉淀。", "updated_by": null, "created_at": "2026-05-14 10:41:09", "updated_at": "2026-05-20 12:19:00", "slug": "zhao-xisheng", "points_total": 0}, {"id": 15, "status": "current", "name": "李子恒", "role": "在读学生", "grade": "2025级", "group": "系统驱动与开发", "avatar": "https://img.remit.ee/api/file/BQACAgUAAyEGAASHRsPbAAEUYd1qD-DmO5w6JfkOKdVgz-yUAAF23W4AArcjAAI46oFUU5UECdw5Caw7BA.png", "intro": "2025级学生，熟练掌握C与Python，专注于Linux驱动开发。", "message": "", "skills": "[\"C\",\"Python\",\"Linux\",\"驱动开发\",\"前端\",\"后端\"]", "projects": "[]", "sort_order": 0, "body": "<p></p>", "updated_by": "2025级 子恒", "created_at": "2026-05-20 10:40:56", "updated_at": "2026-05-22 04:52:13", "slug": "李子恒", "points_total": 100}, {"id": 16, "status": "current", "name": "曹琦琦", "role": "在读学生", "grade": "2025级", "group": "前端", "avatar": "", "intro": "2025级学生，熟练掌握C与Python，专注于Linux驱动开发。", "message": "", "skills": "[\"前端\"]", "projects": "[]", "sort_order": 0, "body": "", "updated_by": "2025级 子恒", "created_at": "2026-05-20 11:52:09", "updated_at": "2026-05-20 11:53:03", "slug": "曹琦琦", "points_total": 100}]}, "projects": {"cols": ["id", "name", "summary", "status", "category", "cover", "tech", "members", "links", "is_displayed", "sort_order", "body", "updated_by", "created_at", "updated_at", "slug"], "rows": [{"id": 1, "name": "AI 知识库助手", "summary": "面向校园资料和工作室文档的智能问答系统", "status": "In progress", "category": "AI application", "cover": "/template_art/ai-dash.png", "tech": "[\"React\",\"Node.js\",\"Python\",\"LLM\"]", "members": "[\"王老师\",\"李同学\"]", "links": "{\"demo\":\"https://example.com\",\"github\":\"https://github.com/example/dev-studio-ai\"}", "is_displayed": 1, "sort_order": 0, "body": "<h1 data-level=\"1\">AI 知识库助手</h1><p>这个项目用于探索校园资料、课程文档和工作室项目文档的智能检索与问答体验。</p><h2 data-level=\"2\">功能亮点</h2><ul><li><p>文档上传与知识库管理</p></li><li><p>自然语言问答</p></li><li><p>引用来源追踪</p></li><li><p>管理后台与权限控制</p></li></ul><h2 data-level=\"2\">当前状态</h2><p>第一版内容为占位项目，后续会替换为真实截图、演示地址和项目复盘。</p><img src=\"https://img.remit.ee/api/file/BQACAgUAAyEGAASHRsPbAAEUYd1qD-DmO5w6JfkOKdVgz-yUAAF23W4AArcjAAI46oFUU5UECdw5Caw7BA.png\" alt=\"BQACAgUAAyEGAASHRsPbAAEUYd1qD-DmO5w6JfkOKdVgz-yUAAF23W4AArcjAAI46oFUU5UECdw5Caw7BA.png\" width=\"512\" data-name=\"BQACAgUAAyEGAASHRsPbAAEUYd1qD-DmO5w6JfkOKdVgz-yUAAF23W4AArcjAAI46oFUU5UECdw5Caw7BA.png\" data-url=\"https://img.remit.ee/api/file/BQACAgUAAyEGAASHRsPbAAEUYd1qD-DmO5w6JfkOKdVgz-yUAAF23W4AArcjAAI46oFUU5UECdw5Caw7BA.png\"><p></p>", "updated_by": "2025级 子恒", "created_at": "2026-05-14 10:41:09", "updated_at": "2026-05-23 04:49:46", "slug": "ai-assistant"}, {"id": 2, "name": "校园服务平台", "summary": "用于课程、活动和工作室事务管理的 Web 系统", "status": "Prototype", "category": "Web platform", "cover": "/template_art/website-dash.png", "tech": "[\"React\", \"TypeScript\", \"PostgreSQL\"]", "members": "[\"王老师\", \"张同学\"]", "links": "{\"demo\": \"https://example.com\", \"github\": \"https://github.com/example/campus-platform\"}", "is_displayed": 1, "sort_order": 0, "body": "# 校园服务平台\n\n这个项目用于承载课程活动、工作室报名、项目管理和通知发布等校园场景。\n\n## 功能亮点\n\n- 活动和报名管理\n- 成员与项目资料维护\n- 通知发布\n- 数据统计看板\n\n## 当前状态\n\n项目处于原型阶段，页面截图和线上地址后续补充。", "updated_by": null, "created_at": "2026-05-14 10:41:09", "updated_at": "2026-05-20 12:19:00", "slug": "campus-platform"}, {"id": 3, "name": "实验数据看板", "summary": "面向实验项目和竞赛项目的数据分析与可视化看板", "status": "Planning", "category": "Data visualization", "cover": "/template_art/research-dash.png", "tech": "[\"Python\", \"SQL\", \"Charts\"]", "members": "[\"李同学\"]", "links": "{\"demo\": \"https://example.com\", \"github\": \"https://github.com/example/data-dashboard\"}", "is_displayed": 1, "sort_order": 0, "body": "# 实验数据看板\n\n这个项目用于展示实验数据、模型结果、竞赛指标和项目运行状态。\n\n## 功能亮点\n\n- 数据导入\n- 指标趋势\n- 图表展示\n- 项目报告导出\n\n## 当前状态\n\n项目仍在规划中，后续会补充真实数据源和展示截图。", "updated_by": null, "created_at": "2026-05-14 10:41:09", "updated_at": "2026-05-20 12:19:00", "slug": "data-dashboard"}]}, "pages": {"cols": ["id", "slug", "title", "description", "body", "updated_by", "updated_at"], "rows": [{"id": 1, "slug": "index", "title": "启航手册", "description": "一个由大学老师和学生共同组成的综合型软件开发实践团队", "body": "# 启航手册\n\nsailor工作室是一个综合型实践团队，成员由大学老师和学生构成。我们关注真实软件项目中的需求理解、产品设计、工程实现、测试交付和持续维护。\n\n## 方向\n\n- Web 前端与全栈应用\n- AI 应用与知识库系统\n- 数据分析与可视化\n- 校园信息化系统\n- 科研原型与竞赛作品\n\n## 培养方式\n\n我们希望每个成员都能经历从“会写功能”到“能交付系统”的完整过程。工作室会通过项目制协作、代码评审、技术分享和阶段复盘帮助成员积累工程经验。\n\n## 对外合作\n\n我们欢迎课程建设、科研项目、校园系统、企业原型和竞赛项目合作。第一版网站中的内容均为占位，后续会逐步替换为真实案例。", "updated_by": null, "updated_at": "2026-05-14 10:41:09"}, {"id": 2, "slug": "join", "title": "登船邀请", "description": "工作室招新与培养方式", "body": "# 登船邀请\n\n我们欢迎对软件开发、AI 应用、产品设计、数据分析和工程协作感兴趣的同学加入。\n\n## 适合你的情况\n\n- 想参与真实项目，而不只是在课堂里完成作业\n- 愿意阅读文档、写文档，并接受代码评审\n- 对 Web、AI、后端、数据、测试或产品设计有持续兴趣\n- 能稳定投入时间完成团队任务\n\n## 你可以先准备\n\n- 一份简单的自我介绍\n- 你做过的课程项目、比赛项目或个人项目\n- 你熟悉的技术栈和想学习的方向\n- 每周可投入的时间\n\n## 登船流程\n\n1. 通过联系方式提交申请\n2. 简单沟通兴趣方向和时间安排\n3. 参与一个小任务或已有项目\n4. 进入对应小组持续协作\n\n具体报名入口后续会替换为真实表单。", "updated_by": null, "updated_at": "2026-05-14 10:41:09"}, {"id": 3, "slug": "contact", "title": "灯塔信箱", "description": "工作室联系与合作方式", "body": "<div class=\"bn-block-group\" data-node-type=\"blockGroup\"><div class=\"bn-block-outer\" data-node-type=\"blockOuter\" data-id=\"1136043d-cf6b-4fbb-957d-abd01542be38\"><div class=\"bn-block\" data-node-type=\"blockContainer\" data-id=\"1136043d-cf6b-4fbb-957d-abd01542be38\"><div class=\"bn-block-content\" data-content-type=\"heading\" data-level=\"1\"><h1 class=\"bn-inline-content\">灯塔信箱</h1></div></div></div><div class=\"bn-block-outer\" data-node-type=\"blockOuter\" data-id=\"0b90ea67-186d-449a-a398-984d1db60eba\"><div class=\"bn-block\" data-node-type=\"blockContainer\" data-id=\"0b90ea67-186d-449a-a398-984d1db60eba\"><div class=\"bn-block-content\" data-content-type=\"paragraph\"><p class=\"bn-inline-content\">第一版网站暂时使用占位联系方式。后续可以替换为工作室真实邮箱、办公室地址、报名表单和合作入口。</p></div></div></div><div class=\"bn-block-outer\" data-node-type=\"blockOuter\" data-id=\"aed8cbc6-f11a-40ae-a4e6-d8b54ee6e62e\"><div class=\"bn-block\" data-node-type=\"blockContainer\" data-id=\"aed8cbc6-f11a-40ae-a4e6-d8b54ee6e62e\"><div class=\"bn-block-content\" data-content-type=\"heading\" data-level=\"2\"><h2 class=\"bn-inline-content\">联系方式</h2></div></div></div><div class=\"bn-block-outer\" data-node-type=\"blockOuter\" data-id=\"c8ea166c-74bf-4a6b-8b96-24f822c21740\"><div class=\"bn-block\" data-node-type=\"blockContainer\" data-id=\"c8ea166c-74bf-4a6b-8b96-24f822c21740\"><div class=\"bn-block-content\" data-content-type=\"bulletListItem\"><p class=\"bn-inline-content\">邮箱：<a target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"mailto:devstudio@example.edu.cn\">devstudio@example.edu.cn</a></p></div></div></div><div class=\"bn-block-outer\" data-node-type=\"blockOuter\" data-id=\"372996af-2b7c-4be3-9b8a-8756e6e130c2\"><div class=\"bn-block\" data-node-type=\"blockContainer\" data-id=\"372996af-2b7c-4be3-9b8a-8756e6e130c2\"><div class=\"bn-block-content\" data-content-type=\"bulletListItem\"><p class=\"bn-inline-content\">地址：河南牧业经济学院 sailor工作室</p></div></div></div><div class=\"bn-block-outer\" data-node-type=\"blockOuter\" data-id=\"0c88b126-a519-461b-92fc-2c34e77e8d29\"><div class=\"bn-block\" data-node-type=\"blockContainer\" data-id=\"0c88b126-a519-461b-92fc-2c34e77e8d29\"><div class=\"bn-block-content\" data-content-type=\"bulletListItem\"><p class=\"bn-inline-content\">合作方向：校园系统、AI 应用、数据平台、科研原型、竞赛项目</p></div></div></div><div class=\"bn-block-outer\" data-node-type=\"blockOuter\" data-id=\"f5d94d58-e211-48a0-b839-4ad63768f5a5\"><div class=\"bn-block\" data-node-type=\"blockContainer\" data-id=\"f5d94d58-e211-48a0-b839-4ad63768f5a5\"><div class=\"bn-block-content\" data-content-type=\"heading\" data-level=\"2\"><h2 class=\"bn-inline-content\">合作建议</h2></div></div></div><div class=\"bn-block-outer\" data-node-type=\"blockOuter\" data-id=\"d7210849-e30a-4eed-be73-bbe5b3bc24b0\"><div class=\"bn-block\" data-node-type=\"blockContainer\" data-id=\"d7210849-e30a-4eed-be73-bbe5b3bc24b0\"><div class=\"bn-block-content\" data-content-type=\"paragraph\"><p class=\"bn-inline-content\">如果你希望发起合作，可以先准备以下信息：</p></div></div></div><div class=\"bn-block-outer\" data-node-type=\"blockOuter\" data-id=\"904e5e67-dc48-4279-b377-a0db07f85423\"><div class=\"bn-block\" data-node-type=\"blockContainer\" data-id=\"904e5e67-dc48-4279-b377-a0db07f85423\"><div class=\"bn-block-content\" data-content-type=\"bulletListItem\"><p class=\"bn-inline-content\">项目背景和目标用户</p></div></div></div><div class=\"bn-block-outer\" data-node-type=\"blockOuter\" data-id=\"4f410136-c952-4d95-b1ee-a27b5b373290\"><div class=\"bn-block\" data-node-type=\"blockContainer\" data-id=\"4f410136-c952-4d95-b1ee-a27b5b373290\"><div class=\"bn-block-content\" data-content-type=\"bulletListItem\"><p class=\"bn-inline-content\">期望解决的问题</p></div></div></div><div class=\"bn-block-outer\" data-node-type=\"blockOuter\" data-id=\"5ab1c5ab-f0dd-4c28-bd7e-44d1db759e04\"><div class=\"bn-block\" data-node-type=\"blockContainer\" data-id=\"5ab1c5ab-f0dd-4c28-bd7e-44d1db759e04\"><div class=\"bn-block-content\" data-content-type=\"bulletListItem\"><p class=\"bn-inline-content\">时间要求</p></div></div></div><div class=\"bn-block-outer\" data-node-type=\"blockOuter\" data-id=\"12ba54c7-c449-41ce-8cab-84d4a565ecbc\"><div class=\"bn-block\" data-node-type=\"blockContainer\" data-id=\"12ba54c7-c449-41ce-8cab-84d4a565ecbc\"><div class=\"bn-block-content\" data-content-type=\"bulletListItem\"><p class=\"bn-inline-content\">是否已有数据、原型或现有系统</p></div></div></div><div class=\"bn-block-outer\" data-node-type=\"blockOuter\" data-id=\"e82c8fbd-44c7-478c-971a-01c9a2f2d837\"><div class=\"bn-block\" data-node-type=\"blockContainer\" data-id=\"e82c8fbd-44c7-478c-971a-01c9a2f2d837\"><div class=\"bn-block-content\" data-content-type=\"bulletListItem\"><p class=\"bn-inline-content\">预期交付物</p></div></div></div><div class=\"bn-block-outer\" data-node-type=\"blockOuter\" data-id=\"dbfb5fe2-5dad-43b8-806c-1ece578bd112\"><div class=\"bn-block\" data-node-type=\"blockContainer\" data-id=\"dbfb5fe2-5dad-43b8-806c-1ece578bd112\"><div class=\"bn-block-content\" data-content-type=\"paragraph\"><p class=\"bn-inline-content\">我们会根据工作室成员安排和项目复杂度评估是否承接。</p></div></div></div><div class=\"bn-block-outer\" data-node-type=\"blockOuter\" data-id=\"18fd60b9-d7f6-4cdb-843d-3e9db6f7193b\"><div class=\"bn-block\" data-node-type=\"blockContainer\" data-id=\"18fd60b9-d7f6-4cdb-843d-3e9db6f7193b\"><div class=\"bn-block-content\" data-content-type=\"paragraph\"><p class=\"bn-inline-content\