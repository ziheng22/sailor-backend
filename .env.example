# --- 环境 ---
# development | production（生产会强制校验密钥与 CORS）
APP_ENV=development

SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DATABASE_URL=sqlite:///./sailor.db

# 生产请生成: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

UPLOAD_DIR=./uploads
UPLOAD_MAX_BYTES=15728640
PUBLIC_BASE_URL=http://localhost:8000
CONTENT_DIR=../contents/studio

# 逗号分隔；生产须为真实前端 HTTPS 域名
CORS_ORIGINS=http://localhost:8001

# 生产必填：API 对外域名（TrustedHost），如 api.yoursite.com
# ALLOWED_HOSTS=api.yoursite.com

# 生产默认关闭 /docs；调试时可设 true
# ENABLE_DOCS=false

AUTH_RATE_LIMIT_PER_MINUTE=30

INVITE_CODE=sailor2026
ADMIN_INVITE_CODE=sailor-admin
SEED_ADMIN_NAME=管理员
SEED_ADMIN_PASSWORD=change-me-admin-password
